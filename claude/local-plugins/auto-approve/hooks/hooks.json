{
  "description": "Auto-approve compound bash commands where each part is individually allowed",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/auto-approve.ts"
          }
        ]
      }
    ]
  }
}
